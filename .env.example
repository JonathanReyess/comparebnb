# ── Backend (FastAPI / uvicorn) ──────────────────────────────────────────────

# Gemini API key (AI Studio or Google Cloud)
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated allowed frontend origins for CORS
# Local:      http://localhost:3000,http://localhost:5173
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# URL where the frontend is hosted (used for Stripe redirect URLs)
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
APP_URL=http://localhost:5173

# Supabase (service role — backend only, never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Stripe (secret key + webhook — backend only)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
STRIPE_CREDITS_PRICE_ID=price_your_credits_price_id_here
STRIPE_SUB_PRICE_ID=price_your_subscription_price_id_here


# ── Frontend (Vite — must be prefixed VITE_) ─────────────────────────────────

# Backend API base URL
# Local:      http://localhost:8000
# Production: https://your-backend.railway.app
VITE_API_BASE=http://localhost:8000

# Supabase (anon key — safe to expose to frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Maps (Places Autocomplete)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Stripe price IDs (mirrored for frontend checkout)
VITE_STRIPE_CREDITS_PRICE_ID=price_your_credits_price_id_here
VITE_STRIPE_SUB_PRICE_ID=price_your_subscription_price_id_here
