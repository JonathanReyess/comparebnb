# Required by the backend (FastAPI)
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed frontend origins (backend CORS)
# In production, set this to your Vercel URL, e.g.:
# ALLOWED_ORIGINS=https://comparebnb.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Required by the frontend (Vite)
# In production, set this to your deployed backend URL, e.g.:
# VITE_API_BASE=https://your-backend.railway.app
VITE_API_BASE=http://localhost:8000
